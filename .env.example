VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only — read by netlify/functions/run-summary.mts, never by the client build.
# Do NOT prefix these with VITE_ — that prefix tells Vite to bake a var into the public bundle,
# which would leak this key to every player's browser. Required for the "Wasteland Recap"
# post-run AI summary; the feature degrades to hidden (not an error) if this is unset.
# Get a key at console.anthropic.com. Test locally with `npm run dev:netlify` (netlify-cli),
# which reads this from a root .env file (gitignored) rather than admin/.env.local — that file is
# for the separate, local-only admin/ tool and is never read by this function.
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional override; defaults to claude-haiku-4-5 if unset.
# ANTHROPIC_MODEL=claude-haiku-4-5
