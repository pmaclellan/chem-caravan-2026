# Copy this file to admin/.env.local and fill in real values.
# admin/.env.local is gitignored — never commit it.
#
# VITE_SUPABASE_URL is the same project URL used by the main app's .env.local.
#
# VITE_SUPABASE_SERVICE_ROLE_KEY is the Supabase "service_role" key (Project Settings > API >
# Project API keys > service_role), NOT the anon key. It bypasses Row Level Security entirely,
# which is what lets this local-only tool read every player's runs. Never put this key in the
# main app's .env.local or in any file under src/ — it must only ever be referenced from admin/,
# which is never built or deployed (see admin/vite.config.ts).

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
